# ──────────────────────────────────────────────────────────
# Synatyx Context Engine — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────

# App
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ── Qdrant ────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=synatyx_context
QDRANT_VECTOR_SIZE=1536

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_L1_MAX_MESSAGES=20

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=context_engine
POSTGRES_USER=context_engine
POSTGRES_PASSWORD=context_engine

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MEMORY_UPDATES=synatyx.memory.updates
KAFKA_TOPIC_SUMMARIZE=synatyx.summarize

# ── Embeddings ────────────────────────────────────────────
# Provider: "sentence-transformers" (local, no API cost) or "openai"
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Only required when EMBEDDING_PROVIDER=openai
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_OPENAI_MODEL=text-embedding-3-small

